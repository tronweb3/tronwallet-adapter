{
    "name": "@tronweb3/tronwallet-adapter-react-ui",
    "version": "1.1.13",
    "description": "A set of out-of-the-box components to make it easy to interact with Tron wallets.",
    "keywords": [
        "TRON",
        "TronWeb",
        "adapter"
    ],
    "author": "tronweb3",
    "repository": {
        "type": "git",
        "url": "https://github.com/tronweb3/tronwallet-adapter"
    },
    "license": "MIT",
    "type": "module",
    "sideEffects": false,
    "engines": {
        "node": ">=16",
        "pnpm": ">=7"
    },
    "main": "./lib/cjs/index.js",
    "module": "./lib/esm/index.js",
    "types": "./lib/types/index.d.ts",
    "exports": {
        ".": {
            "import": "./lib/esm/index.js",
            "require": "./lib/cjs/index.js",
            "types": "./lib/types/index.d.ts"
        },
        "./style.css": "./style.css"
    },
    "files": [
        "lib",
        "src",
        "LICENSE",
        "style.css"
    ],
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "clean": "shx mkdir -p lib && shx rm -rf lib",
        "package": "shx echo '{ \"type\": \"commonjs\" }' > lib/cjs/package.json",
        "test": "vitest run"
    },
    "peerDependencies": {
        "react": "*",
        "react-dom": "*"
    },
    "dependencies": {
        "@tronweb3/tronwallet-abstract-adapter": "workspace:^",
        "@tronweb3/tronwallet-adapter-react-hooks": "workspace:^"
    },
    "devDependencies": {
        "@testing-library/jest-dom": "5.17.0",
        "@testing-library/react": "16.3.2",
        "@testing-library/user-event": "13.5.0",
        "@tronweb3/tronwallet-adapter-tronlink": "workspace:^",
        "@types/react": "18.3.3",
        "@types/react-dom": "18.3.0",
        "@types/testing-library__jest-dom": "5.14.9",
        "@vitejs/plugin-react": "5.2.0",
        "@vitest/browser": "3.2.4",
        "@vitest/ui": "3.2.4",
        "happy-dom": "20.8.8",
        "react": "18.3.1",
        "react-dom": "18.3.1",
        "shx": "0.3.4",
        "vitest": "3.2.4"
    }
}
