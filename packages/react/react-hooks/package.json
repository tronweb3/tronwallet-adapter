{
    "name": "@tronweb3/tronwallet-adapter-react-hooks",
    "version": "1.1.12",
    "description": "A `useWallet()` hook to make it easy to interact with Tron wallets.",
    "keywords": [
        "TRON",
        "TronWeb",
        "adapter"
    ],
    "author": "tronweb3",
    "repository": {
        "type": "git",
        "url": "https://github.com/tronweb3/tronwallet-adapter"
    },
    "license": "MIT",
    "type": "module",
    "sideEffects": false,
    "engines": {
        "node": ">=16",
        "pnpm": ">=7"
    },
    "main": "./lib/cjs/index.js",
    "module": "./lib/esm/index.js",
    "types": "./lib/types/index.d.ts",
    "exports": {
        "require": "./lib/cjs/index.js",
        "import": "./lib/esm/index.js",
        "types": "./lib/types/index.d.ts"
    },
    "files": [
        "lib",
        "src",
        "LICENSE"
    ],
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "clean": "shx mkdir -p lib && shx rm -rf lib",
        "package": "shx echo '{ \"type\": \"commonjs\" }' > lib/cjs/package.json",
        "test": "vitest run"
    },
    "peerDependencies": {
        "react": "*",
        "react-dom": "*"
    },
    "dependencies": {
        "@tronweb3/tronwallet-abstract-adapter": "workspace:^",
        "@tronweb3/tronwallet-adapter-tronlink": "workspace:^"
    },
    "devDependencies": {
        "@testing-library/react": "16.3.2",
        "@types/react": "18.3.3",
        "@types/react-dom": "18.3.0",
        "@vitejs/plugin-react": "5.2.0",
        "@vitest/browser": "3.2.4",
        "@vitest/ui": "3.2.4",
        "eventemitter3": "5.0.4",
        "happy-dom": "20.8.8",
        "react": "18.3.1",
        "react-dom": "18.3.1",
        "shx": "0.3.4",
        "vitest": "3.2.4"
    }
}
