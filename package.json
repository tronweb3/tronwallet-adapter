            "yaml": ">=2.2.2",
            "@babel/traverse": ">=7.23.2",
            "vconsole": ">=3.15.1",
            "@adobe/css-tools": ">=4.3.2",
            "follow-redirects": ">=1.15.6",
            "ws@>=8.0.0 <8.17.1": ">=8.17.1",
            "ws@>=7.0.0 <7.5.10": ">=7.5.10",
            "rollup@>=4.0.0 <4.59.0": ">=4.59.0",
            "elliptic@<6.6.1": ">=6.6.1",
            "element-plus@<=2.11.0": ">=2.11.1",
            "create-ecdh>bn.js": "5.2.3",
            "diffie-hellman>bn.js": "5.2.3",
            "miller-rabin>bn.js": "5.2.3",
            "public-encrypt>bn.js": "5.2.3",
            "next@>=15.0.0 <15.5.10": ">=15.5.10",
            "serialize-javascript@<=7.0.2": ">=7.0.3",
            "esbuild@<=0.24.2": ">=0.25.0",
            "@vitest/browser@>=2.0.4 <2.1.9": ">=2.1.9",
            "vite@>=5.0.0 <5.4.21": "5.4.21",
            "@babel/runtime@<7.26.10": ">=7.26.10",
            "@babel/helpers@<7.26.10": ">=7.26.10",
            "pbkdf2@<=3.1.2": ">=3.1.3",
            "pbkdf2@>=3.0.10 <=3.1.2": ">=3.1.3",
            "form-data@>=4.0.0 <4.0.4": ">=4.0.4",
            "tmp@<=0.2.3": ">=0.2.4",
            "sha.js@<=2.4.11": ">=2.4.12",
            "cipher-base@<=1.0.4": ">=1.0.5",
